# AgentForge Arena — local app environment (copy to .env, optional).
#
# Everything has a working default; you only need this file to override.

# Where the api/worker reach a LOCAL model server. Default = host Ollama.
# Use http://ollama:11434 when running the optional `ollama` compose profile,
# or any local OpenAI-compatible server (LM Studio / llama.cpp / vLLM).
# No hosted/paid APIs are supported.
OLLAMA_BASE_URL=http://host.docker.internal:11434
